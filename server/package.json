{
  "name": "lcc-gatepass-server",
  "version": "1.0.0",
  "description": "A simple boilerplate for creating apis",
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest",
    "build": "tsc && tsc-alias",
    "start": "node -r tsconfig-paths/register dist/index.js",
    "dev": "npx ts-node-dev -r tsconfig-paths/register src/index.ts",
    "format": "prettier . --write",
    "lint": "eslint src/",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:seed:admin": "tsx src/db/seed/admin-seeder.ts",
    "db:seed:student": "tsx src/db/seed/student-seeder.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/libyzxy0/lcc-gatepass-server"
  },
  "keywords": [
    "boilerplate",
    "node-boilerplate",
    "libyzxy0"
  ],
  "author": "Jan Liby Dela Costa (@libyzxy0)",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.22.7",
    "eslint": "^9.39.2",
    "express-rate-limit": "^8.2.1",
    "globals": "^15.6.0",
    "imagekit": "^6.0.0",
    "multer": "^2.0.2",
    "prettier": "3.3.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.49.0"
  },
  "dependencies": {
    "@intosoft/qrcode": "^0.1.4",
    "@neondatabase/serverless": "^0.9.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.31.2",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.14.1",
    "postgres": "^3.4.7",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.15.7",
    "vitest": "^1.6.0"
  }
}
